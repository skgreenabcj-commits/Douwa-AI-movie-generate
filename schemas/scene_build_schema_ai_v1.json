{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "scene_build_schema_ai_v1",
  "description": "STEP_03 Scenes Build の AI 出力スキーマ（AI が返すべき JSON の定義）",
  "type": "object",
  "required": ["scenes"],
  "additionalProperties": false,
  "properties": {
    "scenes": {
      "type": "array",
      "minItems": 2,
      "maxItems": 20,
      "description": "scene の配列。scene_order 昇順で格納すること。",
      "items": {
        "type": "object",
        "required": [
          "scene_id",
          "scene_order",
          "scene_title",
          "scene_summary",
          "scene_purpose",
          "scene_type",
          "scene_target_sec",
          "key_characters",
          "key_events",
          "visual_notes",
          "narration_style"
        ],
        "additionalProperties": false,
        "properties": {
          "scene_id": {
            "type": "string",
            "maxLength": 50,
            "description": "scene 識別子。形式: SC-{project_num}-{order:02d}（例: SC-001-01）"
          },
          "scene_order": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "description": "scene の順序（1始まりの整数）"
          },
          "scene_title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "scene タイトル（端的に、20字以内を目安）"
          },
          "scene_summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "scene の内容サマリー（2〜4文）"
          },
          "scene_purpose": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300,
            "description": "scene の物語的役割・目的（1〜2文）"
          },
          "scene_type": {
            "type": "string",
            "enum": ["intro", "development", "climax", "resolution", "ending"],
            "description": "scene 種別"
          },
          "scene_target_sec": {
            "type": "integer",
            "minimum": 5,
            "maximum": 480,
            "description": "この scene の推奨尺（秒）。scene_max_sec を超えてはならない。"
          },
          "key_characters": {
            "type": "string",
            "maxLength": 300,
            "description": "登場する主要キャラクター（全角「、」区切り。登場なしの場合は空文字）"
          },
          "key_events": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "scene 内で起こる主要な出来事（1〜3文）"
          },
          "visual_notes": {
            "type": "string",
            "maxLength": 500,
            "description": "映像化の方向性ヒント（STEP_06 Visual Bible 用、1〜2文）"
          },
          "narration_style": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300,
            "description": "このscene のナレーション・語りのトーン（1文）"
          }
        }
      }
    }
  }
}
