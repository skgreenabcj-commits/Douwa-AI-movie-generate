{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ImagePromptAiResponse",
  "description": "STEP_07 Image Prompts — AI output schema. One scene per request → image_prompts array contains exactly 1 item.",
  "type": "object",
  "required": ["image_prompts"],
  "properties": {
    "image_prompts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": [
          "scene_record_id",
          "prompt_base",
          "prompt_character",
          "prompt_scene",
          "prompt_composition",
          "negative_prompt"
        ],
        "properties": {
          "scene_record_id":  { "type": "string", "minLength": 1 },
          "character_refs":   {
            "type": "array",
            "items": { "type": "string" },
            "description": "Visual Bible の character category エントリのうち、このシーンに登場するキャラクターの key_name を正確な文字列で列挙する"
          },
          "prompt_base":      { "type": "string", "minLength": 1 },
          "prompt_character": { "type": "string", "minLength": 1 },
          "prompt_scene":     { "type": "string", "minLength": 1 },
          "prompt_composition": { "type": "string", "minLength": 1 },
          "negative_prompt":  { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
