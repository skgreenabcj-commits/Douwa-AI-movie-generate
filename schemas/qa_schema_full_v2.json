{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QaFullRow_v2",
  "description": "Schema for validating a 10_QA GSS write row (v2). 6 questions, 3-choice format.",
  "type": "object",
  "required": [
    "project_id",
    "record_id",
    "generation_status",
    "approval_status",
    "step_id",
    "qa_no",
    "qa_type",
    "question",
    "choice_1",
    "choice_2",
    "choice_3",
    "correct_choice",
    "answer_narration",
    "question_tts",
    "answer_announcement_tts",
    "updated_at",
    "updated_by",
    "notes"
  ],
  "properties": {
    "project_id":               { "type": "string", "minLength": 1 },
    "record_id":                { "type": "string", "minLength": 1 },
    "generation_status":        { "type": "string", "enum": ["GENERATED", "FAILED", "PENDING"] },
    "approval_status":          { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
    "step_id":                  { "type": "string", "minLength": 1 },
    "qa_no":                    { "type": "number" },
    "qa_type":                  { "type": "string", "enum": ["comprehension", "emotion"] },
    "question":                 { "type": "string", "minLength": 1 },
    "choice_1":                 { "type": "string", "minLength": 1 },
    "choice_2":                 { "type": "string", "minLength": 1 },
    "choice_3":                 { "type": "string", "minLength": 1 },
    "correct_choice":           { "type": "string", "enum": ["1", "2", "3"] },
    "answer_narration":         { "type": "string", "minLength": 1 },
    "question_tts":             { "type": "string", "minLength": 1 },
    "answer_announcement_tts":  { "type": "string", "minLength": 1 },
    "updated_at":               { "type": "string" },
    "updated_by":               { "type": "string" },
    "notes":                    { "type": "string" }
  },
  "additionalProperties": false
}
