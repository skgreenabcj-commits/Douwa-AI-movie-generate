{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VisualBibleFullRow",
  "type": "object",
  "required": [
    "project_id",
    "record_id",
    "generation_status",
    "approval_status",
    "step_id",
    "category",
    "key_name",
    "description",
    "color_palette",
    "line_style",
    "lighting",
    "composition_rule",
    "crop_rule",
    "expression_rule",
    "character_rule",
    "background_rule",
    "avoid_rule",
    "reference_note",
    "updated_at",
    "updated_by",
    "notes"
  ],
  "properties": {
    "project_id":        { "type": "string", "minLength": 1 },
    "record_id":         { "type": "string", "minLength": 1 },
    "generation_status": { "type": "string", "enum": ["GENERATED", "FAILED", "PENDING"] },
    "approval_status":   { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
    "step_id":           { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": ["character", "background", "color_theme", "lighting", "style_global", "avoid"]
    },
    "key_name":         { "type": "string", "minLength": 1 },
    "description":      { "type": "string", "minLength": 1 },
    "color_palette":    { "type": "string" },
    "line_style":       { "type": "string" },
    "lighting":         { "type": "string" },
    "composition_rule": { "type": "string" },
    "crop_rule":        { "type": "string" },
    "expression_rule":  { "type": "string" },
    "character_rule":   { "type": "string" },
    "background_rule":  { "type": "string" },
    "avoid_rule":       { "type": "string" },
    "reference_note":   { "type": "string" },
    "updated_at":       { "type": "string" },
    "updated_by":       { "type": "string" },
    "notes":            { "type": "string" }
  },
  "additionalProperties": false
}
