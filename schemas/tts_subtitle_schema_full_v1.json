{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TtsSubtitleFullRow",
  "description": "STEP_08A: 08_TTS_Subtitles GSS書き込み行スキーマ",
  "type": "object",
  "required": [
    "project_id",
    "record_id",
    "generation_status",
    "approval_status",
    "step_id",
    "scene_no",
    "line_no",
    "related_version",
    "tts_text",
    "voice_style",
    "speech_rate",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "project_id":        { "type": "string", "minLength": 1 },
    "record_id":         { "type": "string", "minLength": 1 },
    "generation_status": { "type": "string", "enum": ["GENERATED", "FAILED", "PENDING"] },
    "approval_status":   { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
    "step_id":           { "type": "string" },
    "scene_no":          { "type": "string" },
    "line_no":           { "type": "number" },
    "related_version":   { "type": "string", "enum": ["full", "short"] },
    "tts_text":          { "type": "string", "minLength": 1 },
    "voice_style":       { "type": "string" },
    "speech_rate":       { "type": "string" },
    "pitch_hint":        { "type": "string" },
    "emotion_hint":      { "type": "string" },
    "audio_file":        { "type": "string" },
    "subtitle_text":     { "type": "string" },
    "subtitle_text_alt": { "type": "string" },
    "tc_in":             { "type": "string" },
    "tc_out":            { "type": "string" },
    "subtitle_style":    { "type": "string" },
    "reading_check":     { "type": "string" },
    "lip_sync_note":     { "type": "string" },
    "updated_at":        { "type": "string", "minLength": 1 },
    "updated_by":        { "type": "string" },
    "notes":             { "type": "string" }
  }
}
