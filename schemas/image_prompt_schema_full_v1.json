{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ImagePromptFullRow",
  "description": "STEP_07 Image Prompts — GSS 06_Image_Prompts write row schema. Includes all system fields added after AI validation.",
  "type": "object",
  "required": [
    "project_id",
    "record_id",
    "generation_status",
    "approval_status",
    "step_id",
    "scene_no",
    "related_version",
    "prompt_base",
    "prompt_character",
    "prompt_scene",
    "prompt_composition",
    "negative_prompt",
    "prompt_full",
    "image_take_1",
    "image_take_2",
    "image_take_3",
    "selected_asset",
    "revision_note",
    "style_consistency_check",
    "updated_at",
    "updated_by",
    "notes"
  ],
  "properties": {
    "project_id":        { "type": "string", "minLength": 1 },
    "record_id":         { "type": "string", "minLength": 1 },
    "generation_status": { "type": "string", "enum": ["GENERATED", "FAILED", "PENDING"] },
    "approval_status":   { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
    "step_id":           { "type": "string", "minLength": 1 },
    "scene_no":          { "type": "string" },
    "related_version":   { "type": "string", "minLength": 1 },
    "prompt_base":       { "type": "string", "minLength": 1 },
    "prompt_character":  { "type": "string", "minLength": 1 },
    "prompt_scene":      { "type": "string", "minLength": 1 },
    "prompt_composition": { "type": "string", "minLength": 1 },
    "negative_prompt":   { "type": "string", "minLength": 1 },
    "prompt_full":       { "type": "string", "minLength": 1 },
    "image_take_1":      { "type": "string" },
    "image_take_2":      { "type": "string" },
    "image_take_3":      { "type": "string" },
    "selected_asset":    { "type": "string" },
    "revision_note":     { "type": "string" },
    "style_consistency_check": { "type": "string" },
    "updated_at":        { "type": "string", "minLength": 1 },
    "updated_by":        { "type": "string", "minLength": 1 },
    "notes":             { "type": "string" }
  },
  "additionalProperties": false
}
