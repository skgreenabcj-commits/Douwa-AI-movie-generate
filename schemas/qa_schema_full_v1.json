{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QaFullRow",
  "description": "Schema for validating a 10_QA GSS write row. UNUSED fields (card_visual, duration_sec, learning_goal) must be empty string.",
  "type": "object",
  "required": [
    "project_id",
    "record_id",
    "generation_status",
    "approval_status",
    "step_id",
    "qa_no",
    "related_version",
    "qa_type",
    "question",
    "answer_short",
    "answer_narration",
    "subtitle",
    "card_visual",
    "duration_sec",
    "learning_goal",
    "updated_at",
    "updated_by",
    "notes"
  ],
  "properties": {
    "project_id":        { "type": "string", "minLength": 1 },
    "record_id":         { "type": "string", "minLength": 1 },
    "generation_status": { "type": "string", "enum": ["GENERATED", "FAILED", "PENDING"] },
    "approval_status":   { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
    "step_id":           { "type": "string", "minLength": 1 },
    "qa_no":             { "type": "number" },
    "related_version":   { "type": "string", "enum": ["full", "short"] },
    "qa_type": {
      "type": "string",
      "enum": ["comprehension", "emotion", "vocabulary", "moral"]
    },
    "question":          { "type": "string", "minLength": 1 },
    "answer_short":      { "type": "string", "minLength": 1 },
    "answer_narration":  { "type": "string", "minLength": 1 },
    "subtitle":          { "type": "string", "minLength": 1 },
    "card_visual":       { "type": "string", "enum": [""] },
    "duration_sec":      { "type": "string", "enum": [""] },
    "learning_goal":     { "type": "string", "enum": [""] },
    "updated_at":        { "type": "string" },
    "updated_by":        { "type": "string" },
    "notes":             { "type": "string" }
  },
  "additionalProperties": false
}
